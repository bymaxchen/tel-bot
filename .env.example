# ===== Telegram =====
BOT_TOKEN=你的TelegramBotToken
# 机器人用户名（不带 @），用于生成邀请链接 /invite。例如 @ai_ym_lyf_bot 填 ai_ym_lyf_bot
BOT_USERNAME=

# ===== OpenAI (GPT Image) =====
OPENAI_API_KEY=你的OpenAIKey

# ===== DeepSeek（写小说功能，可选）=====
# 留空则 /novel 命令会提示"未启用"
DEEPSEEK_API_KEY=
# 默认走官方 API；若走中转/自建反代改这里
DEEPSEEK_API_BASE=https://api.deepseek.com
# 主模型（出正文）；默认走 flash——比 pro 快很多且够用；想换 pro 就填 deepseek-v4-pro
DEEPSEEK_MODEL_MAIN=deepseek-v4-flash
# 副模型（跑背景摘要压缩，快便宜就行）
DEEPSEEK_MODEL_SUMMARY=deepseek-v4-flash
# 本地调试：设为 1 会在控制台打印每次 /novel 拼装的 messages 数组和响应内容
NOVEL_DEBUG=
# 本地调试：设为 1 时所有扣积分操作直接放行（spend 恒返回 999999，refund 也不动余额）
# ⚠️ 生产环境绝对不能开！
UNLIMITED_CREDITS=

# ===== RunningHub =====
RH_API_KEY=你的RunningHubKey
# 国内版 .cn / 国际版 .ai（上传/提交/查询必须同一个）
RH_API_BASE=https://www.runninghub.cn

# ===== Redis =====
# Railway 添加 Redis 后会注入 REDIS_URL；本地默认 redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ===== Webhook =====
# 对外公网地址（Railway 自动域名），用于拼 RunningHub 回调地址
PUBLIC_URL=https://你的应用.up.railway.app
# webhook 路径密钥，随机生成一段，防伪造回调
WEBHOOK_SECRET=随机生成一段字符串
# HTTP 端口（Railway 会自动注入 PORT，本地可不填）
PORT=3000

# ===== 管理员（充值 + 告警）=====
# 管理员的 Telegram 用户ID，多个用逗号分隔（也会收到服务异常告警）
ADMIN_IDS=123456789

# ===== 并发控制 =====
# 同时进行的「GPT+上传+提交」最大数量，超出排队。按 OpenAI/RunningHub 承受力调，默认 5
MAX_CONCURRENCY=5

# ===== 图片归档（可选）=====
# 私有频道 ID（形如 -1001234567890）。配置后用户上传的模特图 + 处理结果图都会归档到该频道。
# 前置：先建一个私有频道，把机器人加为管理员，允许「发送消息 / 发送媒体」。
# 留空则关闭归档。
ARCHIVE_CHANNEL_ID=

# 小说提示词归档频道（可选，建议另建一个私有频道）：
# 配置后每次 /novel 生成前，完整拼装的 messages 会作为 .txt 文件发到该频道，方便复盘。
NOVEL_ARCHIVE_CHANNEL_ID=

# 写小说使用教程外链（可选，Google Doc / 语雀 / Notion 都行）
# 配置后 /novel 入口消息底部会多一个「📖 查看使用教程」按钮
NOVEL_TUTORIAL_URL=

# ===== 推广频道入群门（可选）=====
# 配置后 /checkin 必须先加入该频道。前置：机器人需是该频道管理员（getChatMember 才能用）。
# PROMO_CHANNEL_ID  可填 @your_channel（公开频道）或 -1001234567890（私有频道）
# PROMO_CHANNEL_URL 用户点按钮加入的链接：公开频道 https://t.me/your_channel；私有频道用邀请链接 t.me/+xxx
# 两者都留空 → 关闭入群门
PROMO_CHANNEL_ID=
PROMO_CHANNEL_URL=
