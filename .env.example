# ===== Telegram =====
BOT_TOKEN=你的TelegramBotToken

# ===== OpenAI (GPT Image) =====
OPENAI_API_KEY=你的OpenAIKey

# ===== RunningHub =====
RH_API_KEY=你的RunningHubKey
# 国内版 .cn / 国际版 .ai（上传/提交/查询必须同一个）
RH_API_BASE=https://www.runninghub.cn

# ===== Redis =====
# Railway 添加 Redis 后会注入 REDIS_URL；本地默认 redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ===== Webhook =====
# 对外公网地址（Railway 自动域名），用于拼 RunningHub 回调地址
PUBLIC_URL=https://你的应用.up.railway.app
# webhook 路径密钥，随机生成一段，防伪造回调
WEBHOOK_SECRET=随机生成一段字符串
# HTTP 端口（Railway 会自动注入 PORT，本地可不填）
PORT=3000

# ===== 管理员（充值 + 告警）=====
# 管理员的 Telegram 用户ID，多个用逗号分隔（也会收到服务异常告警）
ADMIN_IDS=123456789

# ===== 并发控制 =====
# 同时进行的「GPT+上传+提交」最大数量，超出排队。按 OpenAI/RunningHub 承受力调，默认 5
MAX_CONCURRENCY=5
